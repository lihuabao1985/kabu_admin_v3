<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kabu.admin.rbac.mapper.RolePermissionMapper">

    <select id="findPermissionIdsByRoleId" resultType="long">
        SELECT
            PERMISSION_ID
        FROM M_ROLE_PERMISSION
        WHERE ROLE_ID = #{roleId}
        ORDER BY PERMISSION_ID ASC
    </select>

    <insert id="insertIgnoreBatch">
        <if test="ids != null and ids.size() > 0">
            INSERT IGNORE INTO M_ROLE_PERMISSION (
                ROLE_ID,
                PERMISSION_ID,
                CREATED_AT,
                UPDATED_AT
            ) VALUES
            <foreach item="id" collection="ids" separator=",">
                (#{roleId}, #{id}, #{now}, #{now})
            </foreach>
        </if>
    </insert>

    <delete id="deleteByRoleIdAndPermissionIds">
        DELETE FROM M_ROLE_PERMISSION
        WHERE ROLE_ID = #{roleId}
          <if test="ids != null and ids.size() > 0">
            AND PERMISSION_ID IN
            <foreach item="id" collection="ids" open="(" separator="," close=")">
                #{id}
            </foreach>
          </if>
    </delete>

    <delete id="deleteByRoleId">
        DELETE FROM M_ROLE_PERMISSION
        WHERE ROLE_ID = #{roleId}
    </delete>

</mapper>
